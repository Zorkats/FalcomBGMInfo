EXPORTS
    ; Ordinal 1 is technically DllMain in real XInput, some anti-cheats check this.
    DllMain = Proxy_XInputDllMain                       @1

    XInputGetState = Proxy_XInputGetState               @2
    XInputSetState = Proxy_XInputSetState               @3
    XInputGetCapabilities = Proxy_XInputGetCapabilities @4
    XInputEnable = Proxy_XInputEnable                   @5
    XInputGetDSoundAudioDeviceGuids = Proxy_XInputGetDSoundAudioDeviceGuids @6
    XInputGetBatteryInformation = Proxy_XInputGetBatteryInformation @7
    XInputGetKeystroke = Proxy_XInputGetKeystroke       @8
    XInputGetAudioDeviceIds = Proxy_XInputGetAudioDeviceIds @10

    ; Hidden/Undocumented Functions (Commonly used by games)
    XInputGetStateEx = Proxy_XInputGetStateEx           @100
    XInputWaitForGuideButton = Proxy_XInputWaitForGuideButton @101
    XInputCancelGuideButtonWait = Proxy_XInputCancelGuideButtonWait @102
    XInputPowerOffController = Proxy_XInputPowerOffController @103
    XInputGetBaseBusInformation = Proxy_XInputGetBaseBusInformation @104
    XInputGetCapabilitiesEx = Proxy_XInputGetCapabilitiesEx @108

